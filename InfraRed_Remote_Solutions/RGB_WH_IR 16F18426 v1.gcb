sub light_detect

photosens=readad (an1) ''  FOTO SENSORS PRET GND. gaisma pret samazinas, tumsa palielinas, poti + potencials ir lielaks un AN1 baits palielinas.
if photosens > lux_set then set night_mode on '' atvienojot  sensoru = night mode =1
if photosens-5 < lux_set then set photo_filt_bit on
if photo_off_sec >= 20 then photo_filt_bit=0:set night_mode off:photo_off_sec=0 ''  ========  PHOTO FILTRS  === photo_off_sec pie Timer

end sub

sub IND_LED

if sett_execute_bit=1 then

if full>15 then set LED_ind on else set LED_ind off

else

select case mode_case

case 0
if full<2 then set LED_ind on else set LED_ind off
case 1
if full<2 or ( Full>4 & full<7) then set LED_ind on else set LED_ind off
case 2
if full<2 or ( Full>4 & full<7) or ( Full>9 & full<12)  then set LED_ind on else set LED_ind off
''case 3
''if full<2 or ( Full>4 & full<7) or ( Full>9 & full<12) or ( Full>14 & full<17)  then set LED_ind on else set LED_ind off
end select

end if

end sub
